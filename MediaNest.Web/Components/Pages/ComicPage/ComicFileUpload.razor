@inherits FileUploadProgress

@code {
    protected int finishedFiles = 0;

    protected override async Task UploadFile()
    {
        await OnUploadBtnPressed.InvokeAsync(true);

        if (string.IsNullOrEmpty(SaveDirectory))
            return;

        finishedFiles = 0;
        isUploading = true;
        isUploadFinish = false;
        message = "檔案上傳中...";
        StateHasChanged();

        try
        {
            var saveFolder = Path.Combine(SaveDirectory, SaveSubFolder);
            Directory.CreateDirectory(saveFolder);
            int pageNo = 1;

            foreach (var info in uploadInfos)
            {
                var file = info.File;
                string ext = Path.GetExtension(file.Name);
                var filePath = Path.Combine(saveFolder, $"{pageNo++:D3}{ext}");

                await using Stream readStream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024); // 50MB

                await FileService.SaveStreamAsync(readStream, filePath, file.Size, async (progress) =>
                {
                    info.Progress = progress;
                    finishedFiles = pageNo - 1;
                    await InvokeAsync(StateHasChanged);
                });
            }

            isUploadFinish = true;
            message = $"✅ 上傳完成!! At {saveFolder}";
            await OnUploadFinished.InvokeAsync(true);
        }
        catch (Exception ex)
        {
            message = $"❌ 上傳失敗: {ex.Message}";
            await JS.InvokeVoidAsync("Utils.ShowAlert", $"上傳發生錯誤: {ex.Message}");
            await OnUploadFinished.InvokeAsync(false);
        }
        finally
        {
            isUploading = false;
            StateHasChanged();
        }
    }
}
